<!DOCTYPE html>
<html>
<head>
    <title>Rejestracja - RentalPro</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="auth-container">
        <div class="auth-card">
            <h1>📝 Rejestracja</h1>
            <% if (locals.error) { %>
                <div class="alert error"><%= error %></div>
            <% } %>
            <form method="POST" action="/register" onsubmit="return validateForm()">
                <div class="input-group">
                    <input type="text" name="username" id="username" placeholder="👤 Nazwa użytkownika" required>
                </div>
                <div class="input-group">
                    <input type="email" name="email" id="email" placeholder="📧 Email" required>
                </div>
                <div class="input-group">
                    <input type="password" name="password" id="password" placeholder="🔒 Hasło" required 
                           onkeyup="checkPasswordStrength()">
                    <div id="password-strength" style="margin-top: 10px; font-size: 12px;"></div>
                    <div style="font-size: 12px; color: #718096; margin-top: 5px;">
                        Wymagania: min. 8 znaków, duża i mała litera, cyfra, znak specjalny
                    </div>
                </div>
                <div class="input-group">
                    <input type="password" name="confirm_password" id="confirm_password" 
                           placeholder="🔒 Potwierdź hasło" required>
                </div>
                <button type="submit">Zarejestruj się</button>
            </form>
            <p>Masz już konto? <a href="/login">Zaloguj się</a></p>
        </div>
    </div>
    
    <script>
    function checkPasswordStrength() {
        const password = document.getElementById('password').value;
        const strengthDiv = document.getElementById('password-strength');
        
        let strength = 0;
        if (password.length >= 8) strength++;
        if (password.match(/[a-z]/)) strength++;
        if (password.match(/[A-Z]/)) strength++;
        if (password.match(/[0-9]/)) strength++;
        if (password.match(/[^a-zA-Z0-9]/)) strength++;
        
        const strengthText = ['Bardzo słabe', 'Słabe', 'Średnie', 'Silne', 'Bardzo silne'];
        const strengthColor = ['#fc8181', '#f6ad55', '#f6e05e', '#68d391', '#48bb78'];
        
        if (password.length > 0) {
            strengthDiv.innerHTML = 'Siła hasła: <span style="color: ' + strengthColor[strength-1] + '">' + strengthText[strength-1] + '</span>';
        } else {
            strengthDiv.innerHTML = '';
        }
    }
    
    function validateForm() {
        const password = document.getElementById('password').value;
        const confirmPassword = document.getElementById('confirm_password').value;
        
        const passwordRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[!@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]).{8,}$/;
        
        if (!passwordRegex.test(password)) {
            alert('Hasło musi mieć minimum 8 znaków, zawierać dużą i małą literę, cyfrę oraz znak specjalny!');
            return false;
        }
        
        if (password !== confirmPassword) {
            alert('Hasła nie są identyczne!');
            return false;
        }
        
        return true;
    }
    </script>
</body>
</html>